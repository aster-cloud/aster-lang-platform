{
  "$comment": "aster-lang 生态发布的单一事实源（ADR 0023）。orchestrator(release-train.yml)读它编排发布顺序；各仓 CI 的 pin-consistency gate 据它断言。platformVersion=catalog artifact 自身版本（catalog 内容变更才 bump）；ecosystemVersion=catalog 内 asterLang 值=引擎 Maven 制品内容版本；tsNpmVersion=aster-lang-ts npm 版本；uiMessagesNpmVersion=ui-messages 系列 npm 版本（locales/hi 的前端文案包，独立 cadence）。**以 artifact 粒度建模**：双/多制品仓（locales/hi/test 同时发 Maven+npm）拆成多条 artifact，各有唯一 id；releaseOrder 用 id。",
  "platformVersion": "1.0.6",
  "ecosystemVersion": "1.0.4",
  "tsNpmVersion": "1.0.4",
  "uiMessagesNpmVersion": "1.0.6",
  "$releaseOrderComment": "发布 DAG 的 **artifact 依赖序**（id 粒度，同一层无依赖可并行）。但执行层（orchestrator）须按 (repo, releaseWorkflow) **coalesce**：locales:maven 与 locales:npm 是同一个 aster-lang-locales/release.yml 在同一 v* tag 发的两个制品，只能 dispatch 该 workflow 一次（传 artifactIds 列表），绝不可按 artifact 逐个 dispatch 否则重复 publish。test 例外——test:jvm/test:npm 是两个独立 workflow(release-maven.yml/release-npm.yml)，可真正并行。",
  "releaseOrder": [
    ["platform"],
    ["core:maven", "runtime:maven", "validation:maven", "test:jvm", "test:npm"],
    ["locales:maven", "locales:npm", "hi:maven", "hi:npm"],
    ["truffle:maven"],
    ["ts:npm", "aster-api:service"]
  ],
  "$versionSourceComment": "versionSource 决定 gate 断言方式：literal=源文件硬编码 version=\"X\"（需手工 bump + tag==version gate）；catalog-derived=version=asterLibs.findVersion(\"asterLang\")（派生自该仓 pin 的 platform catalog——gate 须同时断言①确实派生而非字面量 ②expectedPlatformPin==platformVersion，否则 pin 到旧 platform 会稳定派生错误版本）；none=无版本制品。",
  "artifacts": [
    { "id": "platform",          "repo": "aster-lang-platform",   "kind": "catalog", "versionSource": "literal",         "expectedVersion": "1.0.6", "expectedPlatformPin": null,    "releaseWorkflow": "release.yml" },
    { "id": "core:maven",        "repo": "aster-lang-core",        "kind": "maven",   "versionSource": "literal",         "expectedVersion": "1.0.4", "expectedPlatformPin": "1.0.6", "releaseWorkflow": "release.yml" },
    { "id": "runtime:maven",     "repo": "aster-lang-runtime",     "kind": "maven",   "versionSource": "literal",         "expectedVersion": "1.0.4", "expectedPlatformPin": null,    "releaseWorkflow": "release.yml" },
    { "id": "validation:maven",  "repo": "aster-lang-validation",  "kind": "maven",   "versionSource": "literal",         "expectedVersion": "1.0.4", "expectedPlatformPin": null,    "releaseWorkflow": "release.yml" },
    { "id": "test:jvm",          "repo": "aster-lang-test",        "kind": "maven",   "versionSource": "literal",         "expectedVersion": "1.0.4", "expectedPlatformPin": null,    "artifactPath": "packages/jvm", "releaseWorkflow": "release-maven.yml" },
    { "id": "test:npm",          "repo": "aster-lang-test",        "kind": "npm",     "versionSource": "literal",         "expectedVersion": "1.0.2", "expectedPlatformPin": null,    "artifactPath": "packages/js",  "releaseWorkflow": "release-npm.yml", "npmName": "@aster-cloud/aster-lang-test" },
    { "id": "locales:maven",     "repo": "aster-lang-locales",     "kind": "maven",   "versionSource": "catalog-derived", "expectedVersion": "1.0.4", "expectedPlatformPin": "1.0.6", "releaseWorkflow": "release.yml" },
    { "id": "locales:npm",       "repo": "aster-lang-locales",     "kind": "npm",     "versionSource": "literal",         "expectedVersion": "1.0.6", "expectedPlatformPin": "1.0.6", "artifactPath": "ui-messages", "releaseWorkflow": "release.yml", "npmName": "@aster-cloud/ui-messages" },
    { "id": "hi:maven",          "repo": "aster-lang-hi",          "kind": "maven",   "versionSource": "catalog-derived", "expectedVersion": "1.0.4", "expectedPlatformPin": "1.0.6", "releaseWorkflow": "release.yml" },
    { "id": "hi:npm",            "repo": "aster-lang-hi",          "kind": "npm",     "versionSource": "literal",         "expectedVersion": "1.0.6", "expectedPlatformPin": "1.0.6", "artifactPath": "ui-messages", "releaseWorkflow": "release.yml", "npmName": "@aster-cloud/ui-messages-hi" },
    { "id": "truffle:maven",     "repo": "aster-lang-truffle",     "kind": "maven",   "versionSource": "literal",         "expectedVersion": "1.0.4", "expectedPlatformPin": "1.0.6", "releaseWorkflow": "release.yml" },
    { "id": "ts:npm",            "repo": "aster-lang-ts",          "kind": "npm",     "versionSource": "literal",         "expectedVersion": "1.0.4", "expectedPlatformPin": null,    "releaseWorkflow": "release.yml", "npmName": "@aster-cloud/aster-lang-ts" },
    { "id": "aster-api:service", "repo": "aster-api",              "kind": "service", "versionSource": "none",            "expectedVersion": null,    "expectedPlatformPin": "1.0.6", "releaseWorkflow": "deploy.yml" }
  ]
}
